{
  "name": "estoque-celular",
  "version": "0.1.0",
  "description": "Controle de estoque, vendas e trocas para loja de peças e conserto de celular",
  "author": "Jean Vasconcelos <jean.vasconcelos@befective.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "test": "vite build && node test/smoke.js",
    "build": "vite build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.61.1",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "br.com.estoquecelular",
    "productName": "Estoque Celular",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "vasconcelosjean42",
      "repo": "estoque-celular"
    }
  }
}
